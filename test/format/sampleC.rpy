# 经典开场白 —— 没错，就是那个让无数人翘首以盼的蓝色字幕，故事的开端
translate chinese sample_intro_a1b2c3d4:

    # "A long time ago in a galaxy far, far away..."
    "很久很久以前，在一个遥远的星系……"

# 欧比旺的经典问候 —— 克诺比将军的社交名片，自带BGM的“你好”
translate chinese sample_obiwan_5e6f7g8h:

    # Obi-Wan "Hello there!"
    Obi-Wan "你好啊！"

# 格里弗斯将军的名场面 —— 机械肺活量拉满的四刀流点名回礼
translate chinese sample_grievous_9i0j1k2l:

    # General Grievous "General Kenobi!"
    General Grievous "克诺比将军！"

# 欧比旺的嘲讽 —— 高地之王的日常教学，顺便给四刀流上个嘴炮Debuff
translate chinese sample_obiwan_counter_3m4n5o6p:

    # Obi-Wan "You are a bold one."
    Obi-Wan "你可真是胆大包天。"

# 安纳金的沙子名梗 —— 天选之子对地质学的终极控诉，以及泡妞翻车的开端
translate chinese sample_anakin_7q8r9s0t:

    # Anakin "I don't like sand. It's coarse and rough and irritating... and it gets everywhere."
    Anakin "我不喜欢沙子。它又粗又糙又烦人……还会到处乱钻。"

# 帕德梅的失望 —— 议员妻子的眼神逐渐失去高光，感情破裂的经典判决
translate chinese sample_padme_1u2v3w4x:

    # Padmé "You're not the Jedi I fell in love with."
    Padmé "你已不是我爱上的那个绝地武士。"

# 穆斯塔法决战 —— 地形杀大师的决胜宣言，火山边的物理学圣剑
translate chinese sample_anakin_highground_5y6z7a8b:

    # Obi-Wan "It's over, Anakin! I have the high ground!"
    Obi-Wan "结束了，安纳金！我占据了高地！"

# 安纳金的狂妄 —— 被愤怒冲昏头脑的纵身一跃，教科书级别的“不听劝”
translate chinese sample_anakin_underestimate_9c0d1e2f:

    # Anakin "You underestimate my power!"
    Anakin "你小看了我的力量！"

# 欧比旺的悲鸣 —— 看着兄弟在岩浆边烤熟的灵魂呐喊，绝地武士团的心碎时刻
translate chinese sample_obiwan_friend_3g4h5i6j:

    # Obi-Wan "You were my brother, Anakin! I loved you!"
    Obi-Wan "你是我的兄弟，安纳金！我曾爱过你！"

# game/strings/sample_strings_block:
translate chinese strings:

    # 高地梗 —— 战术制高点的含金量，从此成为星战宇宙第一物理学定律
    old "I have the high ground!"
    new "我占据着高地！"

    # 天选之人 —— 欧比旺最后的挽尊，预言粉碎机启动
    old "You were the chosen one!"
    new "你本是天选之人！"

    # 帕尔帕廷的经典台词 —— 议长变脸前的最后通牒，原力闪电蓄力中
    old "It's treason, then."
    new "那就是叛国了。"

    # 欧比旺的问候 —— 四部通用打招呼模板，对面一般接“General Kenobi！”
    old "Hello there!"
    new "你好啊！"

    # 格里弗斯的回应 —— 机械将军的条件反射，看到绝地就掏光剑
    old "General Kenobi!"
    new "克诺比将军！"

    # 安纳金的兴奋 —— 每次飞船起飞前的Flag发言，说完必定出事
    old "This is where the fun begins."
    new "这才有趣起来。"

    # 以下为追加条目（英文版中不存在，测试追加功能）帕尔帕廷的野心 —— 老帕的经典咆哮，宣告民主的葬礼
    old "I am the Senate!"
    new "我就是议会！"

    # 帕尔帕廷的诱惑 —— 西斯尊主的怂恿艺术，一个字让安纳金走上不归路
    old "Do it."
    new "动手吧。"